# OpenAI-compatible endpoint (used by OpenAIToolUseAdapter)
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# Logging
# AGENTZOO_DEBUG=1 enables DEBUG-level logs from all agentzoo.* loggers,
# including subprocess argv, NDJSON lines, tool-call args, and stderr.
# AGENTZOO_LOG_LEVEL overrides the level explicitly (DEBUG/INFO/WARNING/ERROR).
# AGENTZOO_DEBUG=0
# AGENTZOO_LOG_LEVEL=INFO